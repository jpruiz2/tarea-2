#include <stdio.h>

int main()
{
    int n, i, numero, contador = 0;

    printf("Ingresa el tamaño del arreglo: ");
    scanf("%d", &n);

    int arreglo[n];

    for (i = 0; i < n; i++)
    {
        printf("Ingresa el elemento %d: ", i + 1);
        scanf("%d", &arreglo[i]);
    }

    printf("Ingresa el numero que quieres buscar: ");
    scanf("%d", &numero);

    for (i = 0; i < n; i++)
    {
        if (arreglo[i] == numero)
        {
            contador++;
        }
    }

    printf("El numero %d se encuentra %d veces en el arreglo.\n", numero, contador);

    return 0;
}
