#include <stdio.h>
int main()
{
  int positivo = 0, negativo = 0, nulo = 0, num, cont=0;
  while (++cont <= 10)
  {
    printf("Ingresa un entero: \n");
    scanf("%d", &num);
    if (num < 0)
      negativo = negativo + 1;
    else
      if (num > 0)
        positivo = positivo + 1;
      else
        nulo = nulo + 1;
  }
  printf("Nulos: %d\n", nulo);
  printf("Positivos: %d\n", positivo);
  printf("Negativos: %d\n", negativo);

  return 0;
}
