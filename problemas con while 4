#include <stdio.h>
int main()
{
  int num, res = 1, cont = 0;
  printf("Dame un numero natural entero \n");
  scanf("%d", &num);
  if (num < 0)
    printf("Ingrese un numero natural entero \n"); 
  
  else
  {
    while (++cont <= num)
    {
      res = res * cont;
    }
    printf("El factorial de tu numero es:  %d\n", res);
  }

  return 0;
}
