#include <stdio.h>
int main()
{
    int n, i, suma = 0;

    printf("Ingresa el tamaño del arreglo: ");
    scanf("%d", &n);

    int arreglo[n];

    for (i = 0; i < n; i++)
    {
        printf("Ingresa el numero %d: ", i + 1);
        scanf("%d", &arreglo[i]);
        suma = suma + arreglo[i];
    }

    printf("La suma de los elementos del arreglo es: %d\n", suma);

    return 0;
}
